{
  "manifest_version": 3,
  "name": "Folio - Job Application Autofill",
  "short_name": "Folio",
  "version": "1.2.0",
  "description": "Save time on job applications. Folio autofill forms with your private profile, uploads your resume, and keeps all data local. No cloud, no tracking.",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_title": "Folio - Autofill Job Applications",
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "src/options/index.html",
  "author": "Omar Bouhlal",
  "homepage_url": "https://github.com/omarbhl/Folio"
}